{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "noEmit": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "typeRoots": [
      "./node_modules/@types",
      "../mango-mis/node_modules/@types"
    ]
  },
  "include": ["frontend/**/*", "backend/**/*.ts"]
}